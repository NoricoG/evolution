{
    "compilerOptions": {
        "target": "es2023",
        "lib": [
            "es2023",
            "dom"
        ],
        "module": "es2022",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@simulation/*": [
                "src/simulation/*"
            ],
            "@app/*": [
                "src/app/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ],
            "@ui/*": [
                "src/ui/*"
            ]
        }
    }
}
